# Twitter/X API v2 (Basic tier - $100/month - https://developer.x.com)
TWITTER_BEARER_TOKEN=

# Reddit (free OAuth app - https://www.reddit.com/prefs/apps/)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=social_listen:v1.0 (by /u/your_username)

# YouTube (API key from Google Cloud Console)
YOUTUBE_API_KEY=

# Optional
DATABASE_PATH=./data/social_listen.db
LOG_LEVEL=INFO
